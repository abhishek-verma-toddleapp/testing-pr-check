pipeline {
    agent any

    triggers {
        GenericTrigger(
            genericVariables: [
                [key: 'PR_ACTION', value: '$.action'],
                [key: 'PR_NUMBER', value: '$.number'],
                [key: 'PR_TITLE', value: '$.pull_request.title'],
                [key: 'PR_BRANCH', value: '$.pull_request.head.ref'],
                [key: 'TARGET_BRANCH', value: '$.pull_request.base.ref'],
                [key: 'REPO_NAME', value: '$.repository.full_name']
            ],
            token: 'pipeline-repo-a-pr-token',
            causeString: 'PR #$PR_NUMBER - $PR_TITLE',
            regexpFilterText: '$PR_ACTION',
            regexpFilterExpression: '^(opened|reopened)$',
            printContributedVariables: true,
            printPostContent: false,
            silentResponse: false
        )
    }

    environment {
        WEBHOOK_SECRET = credentials('github-secret-repo-a')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Build repo-a') {
            steps {
                echo "Building PR #${PR_NUMBER}: ${PR_TITLE}"
                echo "Branch: ${PR_BRANCH} → ${TARGET_BRANCH}"
            }
        }
        stage('Test repo-a') {
            steps {
                echo 'Testing repo-a...'
            }
        }
        stage('Deploy repo-a') {
            steps {
                echo 'Deploying repo-a to staging...'
            }
        }
    }

    post {
        success {
            githubNotify status: 'SUCCESS',
                         description: 'PR checks passed',
                         context: 'jenkins/pr-check'
        }
        failure {
            githubNotify status: 'FAILURE',
                         description: 'PR checks failed',
                         context: 'jenkins/pr-check'
        }
    }
}
