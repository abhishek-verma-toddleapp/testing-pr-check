pipeline {
    agent any

    triggers {
        githubPullRequests(
            triggerMode: 'HEAVY_HOOKS',
            events: [Open(), Reopened()],
            branchRestriction: null,
            cancelQueued: true
        )
    }

    environment {
        WEBHOOK_SECRET = credentials('github-secret-repo-a')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Build repo-a') {
            steps {
                echo 'Building repo-a...'
            }
        }
        stage('Test repo-a') {
            steps {
                echo 'Testing repo-a...'
            }
        }
        stage('Deploy repo-a') {
            steps {
                echo 'Deploying repo-a to staging...'
            }
        }
    }

    post {
        success {
            githubNotify status: 'SUCCESS',
                         description: 'PR checks passed',
                         context: 'jenkins/pr-check'
        }
        failure {
            githubNotify status: 'FAILURE',
                         description: 'PR checks failed',
                         context: 'jenkins/pr-check'
        }
    }
}
